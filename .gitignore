# Python bytecode cache — auto-generated, never commit
__pycache__/
*.py[cod]
*.pyo

# Python virtual environment
.venv/

# Python tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Node / npm
node_modules/

# Compiled TypeScript output
out/
out-test/

# VS Code extension package — intentionally tracked for distribution
# *.vsix

# OS artefacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/settings.json
.vscode/launch.json

# Gradle local cache (machine-specific, auto-regenerated)
pycharm/.gradle/

# Gradle build output — auto-regenerated by buildPlugin
# pycharm/build/distributions/ is intentionally tracked (release ZIPs)
pycharm/build/classes/
pycharm/build/idea-sandbox/
pycharm/build/instrumented/
pycharm/build/kotlin/
pycharm/build/libs/
pycharm/build/patchedPluginXmlFiles/
pycharm/build/reports/
pycharm/build/resources/
pycharm/build/tmp/
