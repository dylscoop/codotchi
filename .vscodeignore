# Tests (not needed in .vsix)
tests/

# Root test conftest (only needed by pytest)
conftest.py

# TypeScript source (only compiled output in out/ is needed)
src/
tsconfig.json

# Python cache directories
.mypy_cache/
.ruff_cache/
**/__pycache__/
*.pyc

# Python virtual environment
.venv/

# Development tooling config
requirements.txt
.ruff.toml
.mypy.ini
pyrightconfig.json

# Documentation and planning
docs/
DESIGN.md
BUILD_LOG.md

# GitHub workflow files
.github/

# TypeScript source maps and declarations (built output only)
src/**/*.map
**/*.d.ts

# Test and coverage output
.pytest_cache/
__pycache__/
**/__pycache__/
*.pyc
.coverage
htmlcov/

# Editor files
.vscode/settings.json
.vscode/launch.json
**/.DS_Store
Thumbs.db

# Node dev dependencies (vsce bundles only production deps)
node_modules/
