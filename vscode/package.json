{
  "name": "vscode-gotchi",
  "displayName": "vscode_gotchi",
  "description": "Raise a virtual pet while you code",
  "version": "0.2.1",
  "publisher": "vscode-gotchi",
  "repository": {
    "type": "git",
    "url": "https://github.com/dylscoop/vscode_gotchi.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gotchi-sidebar",
          "title": "vscode_gotchi",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "gotchi-sidebar": [
        {
          "type": "webview",
          "id": "gotchiView",
          "name": "Your Pet"
        }
      ]
    },
    "commands": [
      {
        "command": "gotchi.openPanel",
        "title": "Gotchi: Open Pet Panel"
      },
      {
        "command": "gotchi.newGame",
        "title": "Gotchi: Start New Game"
      }
    ],
    "configuration": {
      "title": "vscode_gotchi",
      "properties": {
        "gotchi.fontSize": {
          "type": "string",
          "enum": ["small", "normal", "large"],
          "default": "normal",
          "description": "Font size used in the vscode_gotchi sidebar panel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p tsconfig.test.json && node --test out-test/tests/unit/gameEngine.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  }
}
