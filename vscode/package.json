{
  "name": "vscode-gotchi",
  "displayName": "vscode_gotchi",
  "description": "Raise a virtual pet while you code",
  "version": "0.4.3",
  "publisher": "vscode-gotchi",
  "repository": {
    "type": "git",
    "url": "https://github.com/dylscoop/vscode_gotchi.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gotchi-sidebar",
          "title": "vscode_gotchi",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "gotchi-sidebar": [
        {
          "type": "webview",
          "id": "gotchiView",
          "name": "Your Pet"
        }
      ]
    },
    "commands": [
      {
        "command": "gotchi.openPanel",
        "title": "Gotchi: Open Pet Panel"
      },
      {
        "command": "gotchi.newGame",
        "title": "Gotchi: Start New Game"
      }
    ],
    "configuration": {
      "title": "vscode_gotchi",
      "properties": {
        "gotchi.fontSize": {
          "type": "string",
          "enum": ["small", "normal", "large"],
          "default": "normal",
          "description": "Font size used in the vscode_gotchi sidebar panel."
        },
        "gotchi.enableAttentionCalls": {
          "type": "boolean",
          "default": true,
          "description": "Enables attention calls (the pet notifying you when it needs care). When disabled, the entire attention-call mechanic is skipped — no events fire, no cooldowns run, no state counters update."
        },
        "gotchi.idleThresholdSeconds": {
          "type": "integer",
          "default": 60,
          "minimum": 10,
          "description": "Seconds of no IDE activity before the pet is considered idle (decay rate drops to 10% of normal). Default: 60 seconds."
        },
        "gotchi.idleDeepThresholdSeconds": {
          "type": "integer",
          "default": 600,
          "minimum": 30,
          "description": "Seconds of sustained idle before entering deep idle (stats floored at 20, aging stops). Default: 600 seconds (10 minutes)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p tsconfig.test.json && node --test out-test/tests/unit/gameEngine.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  }
}
