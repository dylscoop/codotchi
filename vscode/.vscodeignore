# Tests (not needed in .vsix)
tests/

# TypeScript source (only compiled output in out/ is needed)
src/
tsconfig.json
tsconfig.test.json

# Compiled test output
out-test/

# Python source (retired — still on disk but not tracked by git)
python/
__pycache__/
**/__pycache__/
*.pyc

# Python virtual environment and tool caches
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Development tooling config
.ruff.toml
.mypy.ini
pyrightconfig.json

# Documentation and planning
docs/
DESIGN.md
BUILD_LOG.md

# GitHub workflow files
.github/

# Editor files
.vscode/settings.json
.vscode/launch.json
**/.DS_Store
Thumbs.db

# Node dev dependencies (vsce bundles only production deps)
node_modules/

# Git
.gitignore
